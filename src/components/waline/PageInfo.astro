---
import config from '@/site-config'
import { cn } from 'astro-pure/utils'
import Pageview from '@/components/waline/Pageview.astro'

interface Props {
  view?: boolean
  comment?: boolean
  class?: string
}

const { view, comment, class: className, ...props } = Astro.props

const path = Astro.url.pathname
const walineEnabled = Boolean(config.integ.waline.enable && config.integ.waline.server)
---

{
  walineEnabled && (
    <div class={cn('text-base text-sm text-muted-foreground', className)} {...props}>
      <span class='waline-pageview-count' data-path={path}></span> 次阅读
      {
        comment && (
          <>
            {' | '}
            <a href='#waline'>
              <span class='waline-comment-count' data-path={path} /> 条评论
            </a>
          </>
        )
      }
    </div>
  )
}

{walineEnabled && view && !comment && <Pageview />}
