---
import { Image } from 'astro:assets'

import { Quote } from 'astro-pure/advanced'
import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import ProjectCard from '@/components/home/ProjectCard.astro'
import Section from '@/components/home/Section.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import avatar from '@/assets/avatar.png'
import config from '@/site-config'

const languages = ['Python', 'PyTorch', 'C', 'C++', 'C#', 'R', 'MySQL', 'PostgreSQL']
const frontend = ['TypeScript', 'Vite', 'Webpack', 'Astro']
const developmentTools = ['VSCode', 'Vim', 'Git', 'Linux', 'Docker', 'Nginx']
const others = ['Markdown', 'LaTeX']

const MAX_POSTS = 10
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS)
---

<PageLayout meta={{ title: '首页' }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={avatar}
        alt='profile'
        class='h-28 w-auto rounded-full border p-1'
        loading='eager'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-bold'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title='中国'>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          <Label
            title='GitHub'
            as='a'
            href='https://github.com/LiZhenxing1998'
            target='_blank'
          >
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>

    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='关于'>
        <p class='text-muted-foreground'>机械工程 / CAE / 编程学习者</p>
        <p class='text-muted-foreground'>
          这里记录我的学习与实践，内容主要围绕机械设计、有限元分析、仿真优化，以及
          一些和编程、写作、效率工具相关的折腾笔记。
        </p>
        <Button title='了解更多' class='w-fit self-end' href='/about' variant='ahead' />
      </Section>
      {
        allPostsByDate.length > 0 && (
          <Section title='文章'>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {allPostsByDate.map((p) => (
                <li class='flex flex-col gap-x-2 sm:flex-row'>
                  <PostPreview post={p} />
                </li>
              ))}
            </ul>
            <Button title='查看更多文章' class='w-fit self-end' href='/blog' variant='ahead' />
          </Section>
        )
      }

      <Section title='教育经历'>
        <Card
          as='a'
          heading='燕山大学'
          subheading='机械制造及其自动化'
          date='2021.08 - 2024.07'
          href='https://mec.ysu.edu.cn/'
        >
         <img
            class='absolute end-0 z-0 m-0 -my-2 h-full w-1/2 object-cover opacity-20'
            src='/images/燕山大学.svg'
          />
        </Card>
        <Card
          as='a'
          heading='燕山大学'
          subheading='机械设计制造及其自动化'
          date='2017.08 - 2021.07'
          href='https://www.ysu.edu.cn/'       
        >
          <img
            class='absolute end-0 z-0 m-0 -my-2 h-full w-1/2 object-cover opacity-20'
            src='/images/燕山大学.svg'
          />
        </Card>
      </Section>

      <Section title='站点入口'>
        <div class='grid grid-cols-1 gap-3 sm:grid-cols-2'>
          <ProjectCard
            href='/blog'
            heading='博客文章'
            subheading='记录机械、仿真、编程与日常学习过程中的思考与实践。'
            imagePath='/src/assets/projects/alex-tyson-2BAXJ7ha74s-unsplash.jpg'
          />
          <ProjectCard
            href='/projects'
            heading='项目与实验'
            subheading='集中展示这个站点本身，以及正在整理中的学习方向与项目主题。'
            imagePath='/src/assets/projects/angelica-teran-Bk9hpaXHK4o-unsplash.jpg'
          />
          <ProjectCard
            href='/about'
            heading='关于我'
            subheading='个人背景、常用工具、站点演进和一些偏生活化的信息。'
            imagePath='/src/assets/projects/kseniia-zapiatkina-yATU3rg8tNI-unsplash.jpg'
          />
          <ProjectCard
            href='/links'
            heading='友链'
            subheading='看看我常访问的网站，也欢迎通过留言交换链接。'
            imagePath='/src/assets/projects/wen-qiao-g_w8I64FiO0-unsplash.jpg'
          />
        </div>
      </Section>

      <Section title='当前关注'>
        <Card
          heading='当前关注'
          subheading='有限元分析、结构优化、工程数值计算，以及如何用 Astro 把这些学习过程整理成持续可维护的个人知识博客。'
          date='现在'
        />
      </Section>

      <Section title='技能栈'>
        <SkillLayout title='语言' skills={languages} />
        <SkillLayout title='前端' skills={frontend} />
        <SkillLayout title='工具' skills={developmentTools} />
        <SkillLayout title='其他' skills={others} />
      </Section>
    </div>
    <Quote class='mt-12' />
  </main>
</PageLayout>
