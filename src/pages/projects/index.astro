---
import { Image } from 'astro:assets'

import { Button, Collapse, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'
import Sponsors from '@/components/projects/Sponsors.astro'
import Sponsorship from '@/components/projects/Sponsorship.astro'
import alipay from '@/assets/alipay-qrcode.jpg'
import wechat from '@/assets/wechat-qrcode.jpg'

const headings = [
  { depth: 2, slug: 'site', text: '站点' },
  { depth: 2, slug: 'writing-topics', text: '写作方向' },
  { depth: 2, slug: 'roadmap', text: '后续计划' },
  { depth: 2, slug: 'sponsorship', text: '赞助支持' }
]
---

<PageLayout title='项目' {headings} view>
  <p>GitHub 活动：</p>
  <p>
    <Image
      src='https://ghchart.rshah.org/659eb9/LiZhenxing1998'
      alt='GitHub 活动图'
      inferSize
      loading='lazy'
    />
  </p>
  <p>
    这一页不再展示主题模板自带的示例项目，而是集中介绍这个站点本身、写作方向和后续整理计划。
  </p>
  <Button title='查看赞助方式' class='w-fit' href='#sponsorship'>
    <Icon class='size-5' name='receive-money' slot='before' />
  </Button>

  <h2 id='site'>站点</h2>
  <ProjectSection
    projects={[
      {
        name: '个人博客',
        description: '基于 Astro 搭建的个人博客，用来沉淀机械、仿真、编程和学习记录。',
        links: [
          { type: 'github', href: 'https://github.com/LiZhenxing1998/my-astro-blog' },
          { type: 'site', href: 'https://lizx.vercel.app/' },
          {
            type: 'doc',
            href: '/about'
          }
        ]
      }
    ]}
  />

  <h2 id='writing-topics'>写作方向</h2>
  <ProjectSection
    projects={[
      {
        name: '机械与仿真',
        description: '围绕 SolidWorks、Creo、ABAQUS、ANSYS 和工程分析方法做记录。',
        links: [{ type: 'site', href: '/blog' }]
      },
      {
        name: '编程与工具链',
        description: '记录 Astro、Markdown、LaTeX 以及效率工具相关的使用经验与踩坑。',
        links: [{ type: 'site', href: '/blog' }]
      }
    ]}
  />
  <Collapse title='当前已经写过的内容类型'>
    <ProjectSection
      projects={[
        {
          name: '有限元与优化',
          description: '例如 ANSYS 拓扑优化方法、约束条件等入门与整理型文章。',
          links: [{ type: 'site', href: '/blog' }]
        },
        {
          name: '子程序与实践笔记',
          description: '例如 Umat 子程序相关的简单示例与经验记录。',
          links: [{ type: 'site', href: '/blog' }]
        }
      ]}
    />
  </Collapse>

  <h2 id='roadmap'>后续计划</h2>
  <ProjectSection
    class='my-2'
    projects={[
      {
        name: '内容清理',
        description: '继续替换模板默认文案，统一页面风格，补齐站点的真实信息。',
        links: [{ type: 'site', href: '/about' }]
      },
      {
        name: '内容扩展',
        description: '补充更多和机械工程、仿真优化、工程编程相关的系列文章。',
        links: [{ type: 'site', href: '/blog' }]
      }
    ]}
  />

  <!-- sponsorship -->
  <h2 id='sponsorship'>赞助支持</h2>
  <p>如果这些内容对你有帮助，欢迎通过赞助支持我继续维护和整理这个博客。</p>
  <Sponsorship
    methods={[
      { name: '微信', icon: 'wechat-pay', image: wechat },
      { name: '支付宝', icon: 'alipay', image: alipay }
    ]}
  />
  <p>感谢以下赞助者：</p>
  <Sponsors
    progressMax={25}
    sponsors={[
      { name: 'Arthals', platform: '微信', amount: 50, date: '2025-11-06' },
      { name: '顾**', platform: '微信', amount: 28, date: '2025-06-23' },
      { name: '匿名', platform: '微信', amount: 20, date: '2022-04-06' },
      { name: '华雄 (1300****71)', platform: 'QQ', amount: 5, date: '2019-12-30' },
      { name: '◌ (1934****45)', platform: 'QQ', amount: 3, date: '2019-12-30' },
      { name: 'C*a (酷安@暴走の蜗牛)', amount: 2, date: '2019-07-02' }
    ]}
  />
</PageLayout>

<style>
  .sponsorship-card {
    & .sponsorship-card-img {
      opacity: 0.3;
      --un-blur: blur(4px);
      filter: var(--un-blur);
    }

    &:hover {
      & .sponsorship-card-icon {
        opacity: 0;
      }
      & .sponsorship-card-img {
        opacity: 1;
        --un-blur: blur(0);
      }
    }
  }
</style>
